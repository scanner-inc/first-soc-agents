{
  "name": "soc-threat-hunt-agent",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "test": "jest --forceExit"
  },
  "jest": {
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "useESM": false }]
    },
    "testMatch": ["**/*.test.ts"],
    "moduleFileExtensions": ["ts", "js", "json"],
    "moduleNameMapper": {
      "^(\\.\\.?/.*)\\.js$": "$1"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.55",
    "dotenv": "^16.4.7"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.5",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.3"
  }
}
